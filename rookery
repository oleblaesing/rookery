#!/usr/bin/env bash

set -eu

export GIT_REVISION="$(git rev-parse --short HEAD)"

toml_get() {
    grep -E "^${1} *=" "./config/rookery/rookery.toml" | head -1 | cut -d= -f2- | tr -d ' "'
}

env_get() {
    grep -E "^${1}=" "./config/rookery/.env" | head -1 | cut -d= -f2-
}

exec_rookery() {
    docker compose exec -T rookery /usr/local/bin/rookery "$@"
}

exec_postgres() {
    local db_pass=$(env_get POSTGRES_PASSWORD)

    docker compose exec -T -e PGPASSWORD="$db_pass" postgres "$@"
}

psql_c() {
    exec_postgres psql -h localhost -U rookery -d rookery -tAqc "$1"
}

if [ "$1" == "init" ]; then
    opt_domain=""
    opt_email=""
    opt_name=""

    shift
    
    while [ $# -gt 0 ]; do
        case "$1" in
            --domain)    shift; opt_domain="$1";    shift ;;
            --email)     shift; opt_email="$1";     shift ;;
            --name)      shift; opt_name="$1";      shift ;;
            *)  break ;;
        esac
    done

    mkdir -p "./config/rookery" "./config/caddy"

    if [ ! -f "./config/rookery/rookery.toml" ]; then
        cp "./config/templates/rookery/rookery.toml" "./config/rookery/rookery.toml"

        if [ -n "$opt_domain" ]; then
            sed -i "s|^domain = \"rookery.example.com\".*|domain = \"${opt_domain}\"|" "./config/rookery/rookery.toml"
        fi
        if [ -n "$opt_email" ]; then
            sed -i "s|^contact_email = \"me@example.com\".*|contact_email = \"${opt_email}\"|" "./config/rookery/rookery.toml"
        fi
        if [ -n "$opt_name" ]; then
            sed -i "s|^instance_name = \"My Rookery Instance\".*|instance_name = \"${opt_name}\"|" "./config/rookery/rookery.toml"
        fi
    fi

    if [ ! -f "./config/rookery/.env" ]; then
        cp "./config/templates/rookery/.env" "./config/rookery/.env"

        db_pass=$(openssl rand -hex 32)

        sed -i "s|^ROOKERY_DB_PASSWORD=$|ROOKERY_DB_PASSWORD=${db_pass}|" "./config/rookery/.env"
        sed -i "s|^POSTGRES_PASSWORD=$|POSTGRES_PASSWORD=${db_pass}|" "./config/rookery/.env"
        sed -i "s|^ROOKERY_MASTER_KEY=$|ROOKERY_MASTER_KEY=$(openssl rand -hex 32)|" "./config/rookery/.env"
        sed -i "s|^ROOKERY_SESSION_KEY=$|ROOKERY_SESSION_KEY=$(openssl rand -hex 32)|" "./config/rookery/.env"
    fi

    if [ ! -f "./config/caddy/Caddyfile" ]; then
        cp "./config/templates/caddy/Caddyfile" "./config/caddy/Caddyfile"

        sed -i "s|@DOMAIN@|${opt_domain}|g" "./config/caddy/Caddyfile"
        sed -i "s|@EMAIL@|${opt_email}|" "./config/caddy/Caddyfile"
    fi

    if [ ! -f "./config/rookery/rookery.service" ]; then
        cp "./config/templates/rookery/rookery.service" "./config/rookery/rookery.service"

        sed -i "s|@USER@|$(whoami)|" "./config/rookery/rookery.service"
    fi
fi

if [ "$1" == "install" ]; then
    install -m644 "./config/rookery/rookery.service" /etc/systemd/system/rookery.service
    systemctl daemon-reload
fi

if [ "$1" == "start" ]; then
    if [ "${2:-}" == "--prod" ]; then
        docker compose --profile prod up -d
    else
        docker compose --profile dev up --build
    fi
fi

if [ "$1" == "stop" ]; then
    docker compose down
fi

if [ "$1" == "update" ]; then
    git fetch
    git pull --ff-only
    docker compose build
fi

if [ "$1" == "create-invite" ]; then
    domain=$(toml_get domain)
    token=$(openssl rand -hex 32)

    psql_c "INSERT INTO invites (token, expires_at) VALUES ('${token}', now() + interval '1 days');"

    if [ "$domain" = "localhost" ]; then
        echo "http://localhost:8080/invite/${token}"
    else
        echo "https://${domain}/invite/${token}"
    fi
fi

if [ "$1" == "check-dns" ]; then
    domain=$(toml_get "domain")

    dkim_ed=$(psql_c "
        SELECT 'v=DKIM1; k=ed25519; p=' || replace(encode(public_key_der, 'base64'), chr(10), '')
        FROM dkim_keys dk
        JOIN domains d ON d.id = dk.domain_id
        WHERE d.domain='${domain}'
            AND dk.selector='rookery-ed25519'
            AND dk.is_active=TRUE
        LIMIT 1;
    ")
    dkim_rsa=$(psql_c "
        SELECT 'v=DKIM1; k=rsa; p=' || replace(encode(public_key_der, 'base64'), chr(10), '')
        FROM dkim_keys dk
        JOIN domains d ON d.id = dk.domain_id
        WHERE d.domain='${domain}'
            AND dk.selector='rookery-rsa'
            AND dk.is_active=TRUE
        LIMIT 1;
    ")
    mtasts_id=$(psql_c "
        SELECT mta_sts_id
        FROM domains
        WHERE domain='${domain}'
            AND is_primary=TRUE
        LIMIT 1;
    ")

    row() {
        local wanted="$(tr -d '"[:space:]' <<< "${3:-}")"
        local actual="$(dig +short "$2" "$1" | tr -d '"[:space:]')"
        local result="[MISS]"

        if [ -n "$actual" ]; then
            if [ -z "$wanted" ]; then
                result="[ OK ]"
            elif [ "$actual" = "$wanted" ]; then
                result="[ OK ]"
            fi
        fi

        printf '%s\t%s\t%s\t%s\n' "$result" "$1" "$2" "${3:-}"
    }

    {
        printf 'STATUS\tTYPE\tNAME\tVALUE\n'

        row A    "$domain"
        row AAAA "$domain"
        row A    "openpgpkey.$domain"
        row AAAA "openpgpkey.$domain"
        row A    "mta-sts.$domain"
        row AAAA "mta-sts.$domain"
        row MX   "$domain"                            "10 $domain."
        row TXT  "$domain"                            "v=spf1 a -all"
        row TXT  "rookery-ed25519._domainkey.$domain" "$dkim_ed"
        row TXT  "rookery-rsa._domainkey.$domain"     "$dkim_rsa"
        row TXT  "_dmarc.$domain"                     "v=DMARC1; p=quarantine; rua=mailto:postmaster@${domain}"
        row TXT  "_mta-sts.$domain"                   "v=STSv1;id=$mtasts_id"
        row TXT  "_smtp._tls.$domain"                 "v=TLSRPTv1; rua=mailto:postmaster@${domain}"
    } | column -t -s $'\t'
fi

if [ "$1" == "user" ]; then
    if [ "$2" = "suspend" ]; then
        psql_c "
            UPDATE users
            SET suspended_at = now()
            FROM addresses
            WHERE users.id = addresses.user_id
                AND lower(addresses.local_part) = lower('$3')
        "
    fi

    if [ "$2" = "unsuspend" ]; then
        psql_c "
            UPDATE users
            SET suspended_at = NULL
            FROM addresses
            WHERE users.id = addresses.user_id
                AND lower(addresses.local_part) = lower('$3')
        "
    fi

    if [ "$2" = "delete" ]; then
        exec_rookery delete-user "$3"
    fi
fi

if [ "$1" == "master-key" ]; then
    if [ "$2" = "rotate" ]; then
        new_key="$(openssl rand -hex 32)"

        exec_rookery rotate-master-key --old-key="$(env_get ROOKERY_MASTER_KEY)" --new-key="$new_key"

        sed -i "s|^ROOKERY_MASTER_KEY=.*|ROOKERY_MASTER_KEY=$new_key|" config/rookery/.env
    fi
fi

if [ "$1" == "relay-client" ]; then
    shift

    exec_rookery relay-client "$@"
fi

if [ "$1" == "backup" ]; then
    tmp_dir="$(mktemp -d)"
    out_file="./rookery-backup-$(date +%Y%m%d-%H%M%S).tar.gz.enc"

    echo -n "password: "
    read -rs pass
    echo -n "confirm: "
    read -rs confirm

    if [ "$pass" != "$confirm" ]; then
        echo "passwords not matching."

        exit 1
    fi

    exec_postgres pg_dump -U rookery -d rookery --format=custom > "$tmp_dir/db.dump"
    docker run --rm -v "rookery_caddy-data:/caddy:ro" docker.io/library/alpine:latest tar -C /caddy -c . > "$tmp_dir/caddy-data.tar"
    docker run --rm -v "rookery_messages-data:/messages:ro" docker.io/library/alpine:latest tar -C /messages --exclude=./exports -c . > "$tmp_dir/messages-data.tar"

    tar -c -C "$tmp_dir" db.dump caddy-data.tar messages-data.tar -C "$(pwd)" config/rookery/rookery.toml config/rookery/.env config/caddy/Caddyfile | gzip | pass="$pass" openssl enc -aes-256-cbc -pbkdf2 -salt -pass env:pass > "$out_file"
fi

if [ "$1" == "restore" ]; then
    tmp_dir="$(mktemp -d)"
    in_file="$2"

    echo -n "password: "
    read -rs pass

    pass="$pass" openssl enc -d -aes-256-cbc -pbkdf2 -pass env:pass < "$in_file" | gunzip | tar -x -C "$tmp_dir/"

    exec_postgres pg_restore -U rookery -d rookery --clean --if-exists < "$tmp_dir/db.dump"
    docker run --rm -v "rookery_caddy-data:/caddy" -i docker.io/library/alpine:latest sh -c 'cd /caddy && tar x' < "$tmp_dir/caddy-data.tar"
    docker run --rm -v "rookery_messages-data:/messages" -i docker.io/library/alpine:latest sh -c 'cd /messages && tar x' < "$tmp_dir/messages-data.tar"

    cp "$tmp_dir/config/rookery/rookery.toml" "./config/rookery/rookery.toml"
    cp "$tmp_dir/config/rookery/.env" "./config/rookery/.env"
    cp "$tmp_dir/config/caddy/Caddyfile" "./config/caddy/Caddyfile"
fi

if [ "$1" == "test" ]; then
    docker compose --profile test run --rm test
fi

if [ "$1" == "vet" ]; then
    docker compose --profile lint run --rm lint
fi
