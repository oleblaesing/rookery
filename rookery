#!/bin/sh
# rookery — operator and developer dispatcher for a rookery instance.
#
# Single entry point for every instance operation: bootstrap, start, stop,
# restart, update, invite generation, test injection, and more.
# Wraps docker compose; operators never need to invoke docker compose directly.
#
# Usage: ./rookery <subcommand> [flags] [args]
#        ./rookery help <subcommand>
#
# See docs/adr/ADR-0033.md for rationale and the full subcommand surface.

set -eu

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOKERY_SMTP="${ROOKERY_SMTP:-smtp://localhost:25}"
ROOKERY_HTTP="${ROOKERY_HTTP:-http://localhost:8080}"
# Global used by the send-mail encrypted path for temp-dir cleanup.
_SEND_MAIL_TMPDIR=""
# Passed as a build arg so the binary embeds the git hash for cache busting.
GIT_REVISION="$(git -C "$SCRIPT_DIR" rev-parse --short HEAD 2>/dev/null || echo dev)"
export GIT_REVISION

# ---------------------------------------------------------------------------
# Utilities
# ---------------------------------------------------------------------------

die()  { printf 'rookery: error: %s\n' "$*" >&2; exit 1; }
info() { printf 'rookery: %s\n'        "$*" >&2; }

# Run docker compose against the project compose file, regardless of CWD.
dc() { docker compose -f "$SCRIPT_DIR/compose.yaml" "$@"; }

# Fail with a one-line hint if init has not been run.
need_init() {
    if [ ! -f "$SCRIPT_DIR/.env" ] || [ ! -f "$SCRIPT_DIR/rookery.toml" ]; then
        die ".env or rookery.toml missing — run './rookery init' first"
    fi
}

# Read a string value from rookery.toml on the host.
toml_get() {
    grep -E "^[[:space:]]*${1}[[:space:]]*=" "$SCRIPT_DIR/rookery.toml" \
        | head -1 \
        | sed 's/.*=[[:space:]]*"\([^"]*\)".*/\1/'
}

# Read a variable from .env; prints the value (empty if missing).
env_get() {
    grep -E "^${1}=" "$SCRIPT_DIR/.env" 2>/dev/null | head -1 | cut -d= -f2-
}

# Write a variable to .env if it is missing or empty.
# Usage: env_gen VAR [value]   — omit value to auto-generate with openssl.
env_gen() {
    local var="$1" val="${2:-}"
    local cur
    cur=$(env_get "$var")
    if [ -z "$cur" ]; then
        grep -v "^${var}=" "$SCRIPT_DIR/.env" > "$SCRIPT_DIR/.env.tmp" 2>/dev/null \
            && mv "$SCRIPT_DIR/.env.tmp" "$SCRIPT_DIR/.env" || true
        [ -z "$val" ] && val=$(openssl rand -hex 32)
        printf '%s=%s\n' "$var" "$val" >> "$SCRIPT_DIR/.env"
        info "generated $var"
    fi
}

# ---------------------------------------------------------------------------
# init
# ---------------------------------------------------------------------------
cmd_init() {
    local opt_domain="" opt_email="" opt_name="" opt_user="" opt_no_prompt=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --domain)    shift; opt_domain="${1:-}";    shift ;;
            --email)     shift; opt_email="${1:-}";     shift ;;
            --name)      shift; opt_name="${1:-}";      shift ;;
            --user)      shift; opt_user="${1:-}";      shift ;;
            --no-prompt) opt_no_prompt=1;               shift ;;
            --) shift; break ;;
            -*) die "unknown flag: $1" ;;
            *)  break ;;
        esac
    done

    command -v openssl >/dev/null 2>&1 \
        || die "openssl is required for secret generation — install it and retry"

    # ---- rookery.toml -------------------------------------------------------
    if [ ! -f "$SCRIPT_DIR/rookery.toml" ]; then
        cat > "$SCRIPT_DIR/rookery.toml" << 'TOML'
# rookery.toml — instance configuration file.
#
# Generated by `./rookery init`. Edit the values below, then run
# `./rookery restart` to apply changes.
#
# Secrets (DB password, master key, session key) are NOT in this file.
# They come from environment variables; see compose.yaml.
#
# Changes to this file require a server restart.
#
# Every setting below includes its default value so you can see what you're
# changing. You only need to set values that differ from the default.

# --------------------------------------------------------------------------- #
# Required settings
# --------------------------------------------------------------------------- #

# Primary mail domain for this instance. All @<domain> addresses live here.
# Users can add their own custom domains later (see §5.2b of PLAN.md).
domain = "rookery.example"        # CHANGE_ME

# Let's Encrypt contact email. Used by Caddy (the reverse proxy that handles
# TLS) for expiry notices. Set it in Caddyfile too. Optional here — it is not
# read by the rookery binary itself.
contact_email = "admin@rookery.example"   # CHANGE_ME (optional)

# Human-readable display name shown to users on signup pages.
# Defaults to the value of `domain` if not set.
instance_name = "My Rookery"      # optional

# --------------------------------------------------------------------------- #
# HTTP listener
# --------------------------------------------------------------------------- #
[http]
# Bind address. 0.0.0.0 = all interfaces.
host = "0.0.0.0"

# Port for the HTTP server. Default: 8080.
#
# rookery always serves plain HTTP. TLS termination is handled by Caddy (the
# reverse proxy defined in Caddyfile). In development you hit this port
# directly in your browser. In production Caddy forwards HTTPS traffic here.
# Change this only if 8080 conflicts with something else on your host.
port = 8080

# --------------------------------------------------------------------------- #
# Logging
# --------------------------------------------------------------------------- #
[log]
# Minimum log level to emit. One of: debug, info, warn, error.
# Structured JSON output to stdout. Default: info.
level = "info"

# --------------------------------------------------------------------------- #
# Storage
# --------------------------------------------------------------------------- #
[storage]
# Filesystem path where raw .eml message files are stored, content-addressed
# as messages/sha256/ab/cd/<hash>.eml. Must be on the rookery-messages volume.
# Default: /var/lib/rookery/messages.
#
# This must match the bind mount in compose.yaml. If you change it here you
# must also change the volume mount, or messages will be written to the
# container's writable layer and lost on container replacement.
message_dir = "/var/lib/rookery/messages"

# --------------------------------------------------------------------------- #
# SMTP
# --------------------------------------------------------------------------- #
[smtp]
# Maximum accepted message size in bytes. Default: 26214400 (25 MiB).
# Note: PGP base64 encoding inflates messages by ~33%, so a 16 MiB plaintext
# attachment will become ~21 MiB on the wire. Size accordingly.
max_message_bytes = 26214400

# Per-user outbound rate limit: messages per hour. Default: 200.
outbound_rate_limit_per_user = 200

# Per-user outbound rate limit: messages per day. Default: 1000.
outbound_daily_limit_per_user = 1000

# Per-destination-domain outbound rate limit: messages per hour. Default: 5000.
outbound_rate_limit_per_domain = 5000

# Route all outbound SMTP through a relay host instead of direct MX lookup.
# Useful when outbound port 25 is blocked (ISP/cloud NAT) or in development.
# Leave unset for direct MX delivery (production default).
# relay_host = "smtp-relay.example.com"
# relay_port = 25

# --------------------------------------------------------------------------- #
# Per-instance policy
# --------------------------------------------------------------------------- #
[policy]
# Default per-user mailbox quota in bytes. Default: 5368709120 (5 GiB).
# Per-user overrides via: UPDATE users SET quota_bytes = ... WHERE ...;
default_quota_bytes = 5368709120

# Days before messages in Trash are hard-deleted. Default: 30.
# Set to 0 for immediate hard delete on trash.
trash_retention_days = 30

# Days of inactivity before a session expires. Default: 7.
session_expiry_days = 7

# Log connecting IP addresses on the web UI and submission ports.
# Default: false (pseudonymity-preserving). Set to true only if you understand
# the trade-off: logging IPs enables abuse investigation at the cost of
# undermining the pseudonymity property the system is designed to provide.
# See §5.4, §11.2 of PLAN.md.
log_connecting_ips = false
TOML
        info "created rookery.toml"

        if [ -z "$opt_domain" ] && [ "$opt_no_prompt" -eq 0 ]; then
            printf 'rookery: primary domain (e.g. rookery.example.com): ' >&2
            read -r opt_domain
        fi
        if [ -z "$opt_email" ] && [ "$opt_no_prompt" -eq 0 ]; then
            printf "rookery: Let's Encrypt contact email (Enter to skip): " >&2
            read -r opt_email
        fi
        if [ -z "$opt_name" ] && [ "$opt_no_prompt" -eq 0 ]; then
            printf 'rookery: instance display name (Enter to use domain): ' >&2
            read -r opt_name
        fi

        if [ -n "$opt_domain" ]; then
            sed -i "s|^domain = \"rookery.example\".*|domain = \"${opt_domain}\"|" \
                "$SCRIPT_DIR/rookery.toml"
        fi
        if [ -n "$opt_email" ]; then
            sed -i "s|^contact_email = \"admin@rookery.example\".*|contact_email = \"${opt_email}\"|" \
                "$SCRIPT_DIR/rookery.toml"
        fi
        if [ -n "$opt_name" ]; then
            sed -i "s|^instance_name = \"My Rookery\".*|instance_name = \"${opt_name}\"|" \
                "$SCRIPT_DIR/rookery.toml"
        fi
    else
        info "rookery.toml already exists — skipping"
    fi

    # ---- .env (secrets) -----------------------------------------------------
    if [ ! -f "$SCRIPT_DIR/.env" ]; then
        touch "$SCRIPT_DIR/.env"
    fi
    # Both names carry the same value: ROOKERY_DB_PASSWORD for the Go server,
    # POSTGRES_PASSWORD for the postgres container image.
    local db_pass
    db_pass=$(env_get ROOKERY_DB_PASSWORD)
    [ -z "$db_pass" ] && db_pass=$(openssl rand -hex 32)
    env_gen ROOKERY_DB_PASSWORD "$db_pass"
    env_gen POSTGRES_PASSWORD   "$db_pass"
    env_gen ROOKERY_MASTER_KEY
    env_gen ROOKERY_SESSION_KEY

    # ---- Caddyfile ----------------------------------------------------------
    if [ ! -f "$SCRIPT_DIR/Caddyfile" ]; then
        local domain email
        domain=$(toml_get domain)
        email=$(toml_get contact_email)

        [ -z "$domain" ] && domain="rookery.example"
        [ "$domain" = "rookery.example" ] \
            && info "warning: domain is still 'rookery.example' — edit rookery.toml before going live"

        {
            # Global options block.
            if [ -n "$email" ] && [ "$email" != "admin@rookery.example" ]; then
                printf '{\n\temail %s\n\ton_demand_tls {\n\t\task http://rookery:8080/internal/tls-ask\n\t\tinterval 2m\n\t\tburst 5\n\t}\n}\n\n' "$email"
            else
                printf '{\n\ton_demand_tls {\n\t\task http://rookery:8080/internal/tls-ask\n\t\tinterval 2m\n\t\tburst 5\n\t}\n}\n\n'
            fi
            # Primary domain + standard subdomains (explicit ACME certs).
            printf '%s openpgpkey.%s mta-sts.%s {\n\treverse_proxy rookery:8080\n}\n\n' \
                "$domain" "$domain" "$domain"
            # Catch-all block for custom-domain CNAMEs (on-demand TLS).
            # Caddy asks /internal/tls-ask before issuing any cert in this block.
            printf ':443 {\n\ttls {\n\t\ton_demand\n\t}\n\treverse_proxy rookery:8080\n}\n'
        } > "$SCRIPT_DIR/Caddyfile"
        info "generated Caddyfile for domain '${domain}'"
    else
        info "Caddyfile already exists — skipping"
    fi

    # ---- ./rookery.service --------------------------------------------------
    if [ ! -f "$SCRIPT_DIR/rookery.service" ]; then
        local svc_user="${opt_user:-$(whoami)}"
        cat > "$SCRIPT_DIR/rookery.service" << EOF
[Unit]
Description=rookery mail server
After=docker.service network-online.target
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/rookery
ExecStart=/opt/rookery/rookery start --prod -d
ExecStop=/opt/rookery/rookery stop
User=${svc_user}

[Install]
WantedBy=multi-user.target
EOF
        info "staged rookery.service with User=${svc_user}"
    else
        info "rookery.service already exists — skipping"
    fi

    printf '\n' >&2
    info "init complete."
    info ""
    info "  IMPORTANT: back up .env — especially ROOKERY_MASTER_KEY."
    info "  Losing it bricks DKIM keys, sessions, and ACME credentials."
    info ""
    info "Next steps:"
    info "  sudo ./rookery install          # copy systemd unit, daemon-reload"
    info "  sudo systemctl enable --now rookery"
    info "  ./rookery invite create         # generate the first invite URL"
}

# ---------------------------------------------------------------------------
# install
# ---------------------------------------------------------------------------
cmd_install() {
    [ "$(id -u)" -eq 0 ] \
        || die "rookery install must be run as root (use: sudo ./rookery install)"
    [ -f "$SCRIPT_DIR/rookery.service" ] \
        || die "rookery.service not found — run './rookery init' first"
    install -m644 "$SCRIPT_DIR/rookery.service" /etc/systemd/system/rookery.service
    systemctl daemon-reload
    info "systemd unit installed at /etc/systemd/system/rookery.service"
    info "Run: sudo systemctl enable --now rookery"
}

# ---------------------------------------------------------------------------
# start [--prod] [extra docker compose up flags]
# ---------------------------------------------------------------------------
cmd_start() {
    local prod=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --prod) prod=1; shift ;;
            *)      break ;;
        esac
    done
    need_init
    if [ "$prod" -eq 1 ]; then
        dc --profile prod up --build "$@"
    else
        dc --profile dev up --build "$@"
    fi
}

# ---------------------------------------------------------------------------
# stop
# ---------------------------------------------------------------------------
cmd_stop() {
    need_init
    dc down "$@"
}

# ---------------------------------------------------------------------------
# restart [--prod] [extra flags]
# ---------------------------------------------------------------------------
cmd_restart() {
    need_init
    cmd_stop
    cmd_start "$@"
}

# ---------------------------------------------------------------------------
# update
# ---------------------------------------------------------------------------
cmd_update() {
    need_init
    git -C "$SCRIPT_DIR" fetch \
        || die "git fetch failed"
    git -C "$SCRIPT_DIR" pull --ff-only \
        || die "git pull --ff-only failed — branch has diverged or has local commits; resolve manually"
    dc build
    info "update complete — restart to apply: sudo systemctl restart rookery"
}

# ---------------------------------------------------------------------------
# logs [service]
# ---------------------------------------------------------------------------
cmd_logs() {
    dc logs -f "${1:-rookery}"
}

# ---------------------------------------------------------------------------
# ps
# ---------------------------------------------------------------------------
cmd_ps() {
    dc ps "$@"
}

# ---------------------------------------------------------------------------
# invite create [validity_days]
# ---------------------------------------------------------------------------
cmd_invite_create() {
    need_init

    local validity="${1:-}"
    case "$validity" in
        "")       ;;
        *[!0-9]*) die "validity_days must be a positive integer (got '${validity}')" ;;
    esac

    local domain
    domain=$(toml_get domain)
    [ -n "$domain" ] || die "could not read domain from rookery.toml"

    local token
    token=$(openssl rand -hex 32)
    [ -n "$token" ] || die "failed to generate invite token"

    local expires_sql
    if [ -n "$validity" ]; then
        expires_sql="now() + interval '${validity} days'"
    else
        expires_sql="NULL"
    fi

    local db_pass
    db_pass=$(env_get POSTGRES_PASSWORD)
    [ -n "$db_pass" ] || die "POSTGRES_PASSWORD not found in .env"

    dc exec -T \
        -e PGPASSWORD="$db_pass" \
        postgres \
        psql -h localhost -U rookery -d rookery -q -t \
        -c "INSERT INTO invites (token, expires_at) VALUES ('${token}', ${expires_sql});" \
        >/dev/null

    case "$domain" in
        localhost|127.*|10.*|172.1[6-9].*|172.2[0-9].*|172.3[0-1].*|192.168.*|::1)
            # Read the HTTP port from rookery.toml; default 8080.
            local http_port
            http_port=$(grep -E "^[[:space:]]*port[[:space:]]*=" \
                "$SCRIPT_DIR/rookery.toml" 2>/dev/null \
                | head -1 | sed 's/.*=[[:space:]]*//' | tr -d ' "')
            [ -z "$http_port" ] && http_port="8080"
            printf 'http://%s:%s/invite/%s\n' "$domain" "$http_port" "$token"
            ;;
        *)
            printf 'https://%s/invite/%s\n' "$domain" "$token"
            ;;
    esac
}

cmd_invite() {
    case "${1:-}" in
        create) shift; cmd_invite_create "$@" ;;
        "")     die "usage: rookery invite create [validity_days]" ;;
        *)      die "unknown invite subcommand '${1}' — try: rookery invite create" ;;
    esac
}

# ---------------------------------------------------------------------------
# send-mail [flags] <to> [from] [subject] [body]
# ---------------------------------------------------------------------------

# Wrapper called by the encrypted path; uses the temp homedir set in
# _SEND_MAIL_TMPDIR so we never touch the operator's own keyring.
_send_mail_gpg() {
    gpg --homedir "$_SEND_MAIL_TMPDIR" --batch --yes --quiet "$@"
}

_send_mail_cleanup() {
    [ -n "$_SEND_MAIL_TMPDIR" ] && rm -rf -- "$_SEND_MAIL_TMPDIR"
    _SEND_MAIL_TMPDIR=""
}

cmd_send_mail() {
    local encrypted=0 pubkey_file="" fetch_key=0

    while [ $# -gt 0 ]; do
        case "$1" in
            --encrypted) encrypted=1; shift ;;
            --pubkey)
                shift
                pubkey_file="${1:-}"
                [ -n "$pubkey_file" ] || die "--pubkey requires a file path argument"
                shift ;;
            --fetch-key) fetch_key=1; shift ;;
            --) shift; break ;;
            -*) die "unknown flag: $1" ;;
            *)  break ;;
        esac
    done

    local to="${1:-}"
    local from="${2:-sender@example.com}"
    local subject="${3:-test message $(date '+%H:%M:%S')}"
    local body="${4:-This is a test message injected by rookery send-mail at $(date).}"

    [ -n "$to" ] || {
        printf 'usage: rookery send-mail [--encrypted --pubkey <file>|--fetch-key] <to> [from] [subject] [body]\n' >&2
        exit 1
    }

    if [ "$encrypted" -eq 1 ] && [ -z "$pubkey_file" ] && [ "$fetch_key" -eq 0 ]; then
        die "--encrypted requires either --pubkey <file> or --fetch-key"
    fi
    if [ -n "$pubkey_file" ] && [ "$fetch_key" -eq 1 ]; then
        die "--pubkey and --fetch-key are mutually exclusive"
    fi
    if { [ -n "$pubkey_file" ] || [ "$fetch_key" -eq 1 ]; } && [ "$encrypted" -eq 0 ]; then
        die "--pubkey / --fetch-key require --encrypted"
    fi

    # ---- Plaintext path -----------------------------------------------------
    if [ "$encrypted" -eq 0 ]; then
        printf '%s' "From: ${from}
To: ${to}
Subject: ${subject}
MIME-Version: 1.0
Content-Type: text/plain; charset=utf-8

${body}
" | curl -s \
            --url "${ROOKERY_SMTP}" \
            --mail-from "${from}" \
            --mail-rcpt "${to}" \
            --upload-file -
        printf 'sent (plaintext): %s\n  from: %s\n  to:   %s\n' "$subject" "$from" "$to"
        return 0
    fi

    # ---- Encrypted path — requires gpg --------------------------------------
    command -v gpg >/dev/null 2>&1 \
        || die "gpg is required for --encrypted (install gnupg2)"

    _SEND_MAIL_TMPDIR="$(mktemp -d)"
    trap '_send_mail_cleanup' EXIT INT TERM

    if [ "$fetch_key" -eq 1 ]; then
        command -v python3 >/dev/null 2>&1 \
            || die "python3 is required for --fetch-key (WKD hash computation)"

        local local_part domain_part wkd_hash http_status
        local_part="${to%%@*}"
        domain_part="${to##*@}"

        wkd_hash=$(python3 - "$local_part" <<'PYEOF'
import sys, hashlib
ALPHA = "ybndrfg8ejkmcpqxot1uwisza345h769"
local = sys.argv[1].lower().encode()
digest = hashlib.sha1(local).digest()
bits = int.from_bytes(digest, 'big')
chars = []
for _ in range(32):
    chars.append(ALPHA[bits & 0x1f])
    bits >>= 5
print(''.join(reversed(chars)))
PYEOF
)
        local wkd_url="${ROOKERY_HTTP}/.well-known/openpgpkey/${domain_part}/hu/${wkd_hash}"
        pubkey_file="${_SEND_MAIL_TMPDIR}/recipient.pgp"
        info "fetching public key via WKD: ${wkd_url}"
        http_status=$(curl -s -o "$pubkey_file" -w "%{http_code}" "$wkd_url")
        [ "$http_status" = "200" ] \
            || die "WKD key fetch returned HTTP ${http_status} — ${wkd_url}"
        _send_mail_gpg --import "$pubkey_file" 2>/dev/null
    else
        [ -f "$pubkey_file" ] || die "public key file not found: ${pubkey_file}"
        _send_mail_gpg --import "$pubkey_file" 2>/dev/null
    fi

    local fingerprint
    fingerprint=$(_send_mail_gpg --with-colons --list-keys 2>/dev/null \
        | awk -F: '/^fpr/{print $10; exit}')
    [ -n "$fingerprint" ] || die "could not read fingerprint from the imported key"
    printf '%s:6:\n' "$fingerprint" | _send_mail_gpg --import-ownertrust 2>/dev/null

    local body_file="${_SEND_MAIL_TMPDIR}/body.txt"
    local cipher_file="${_SEND_MAIL_TMPDIR}/body.pgp"
    printf '%s\n' "$body" > "$body_file"
    _send_mail_gpg --armor \
        --recipient "$fingerprint" \
        --output "$cipher_file" \
        --encrypt "$body_file" 2>/dev/null

    local encrypted_body
    encrypted_body=$(cat "$cipher_file")

    local boundary="rookery_pgp_$(date '+%s')_boundary"
    local date_hdr message_id
    date_hdr="$(date -R 2>/dev/null || date '+%a, %d %b %Y %H:%M:%S %z')"
    message_id="rookery-$(date '+%s')@rookery.test"

    printf '%s' "From: ${from}
To: ${to}
Subject: ${subject}
Date: ${date_hdr}
Message-ID: <${message_id}>
MIME-Version: 1.0
Content-Type: multipart/encrypted; protocol=\"application/pgp-encrypted\"; boundary=\"${boundary}\"

--${boundary}
Content-Type: application/pgp-encrypted

Version: 1

--${boundary}
Content-Type: application/octet-stream; name=\"encrypted.asc\"
Content-Disposition: inline; filename=\"encrypted.asc\"

${encrypted_body}

--${boundary}--
" | curl -s \
        --url "${ROOKERY_SMTP}" \
        --mail-from "${from}" \
        --mail-rcpt "${to}" \
        --upload-file -

    printf 'sent (pgp-encrypted): %s\n  from: %s\n  to:   %s\n  key:  %s\n' \
        "$subject" "$from" "$to" "$fingerprint"

    _send_mail_cleanup
    trap - EXIT INT TERM
}

# ---------------------------------------------------------------------------
# check-dns [--resolver <addr>]
# ---------------------------------------------------------------------------
cmd_check_dns() {
    need_init

    local domain resolver=""
    domain=$(toml_get domain)
    [ -n "$domain" ] || die "could not read domain from rookery.toml"

    # Defence against SQL string interpolation below: domains contain only
    # letters, digits, hyphens, and dots — anything else is operator error.
    case "$domain" in
        ''|*[!a-zA-Z0-9.-]*|.*|*.|*..*) die "invalid domain '$domain' in rookery.toml" ;;
    esac

    while [ $# -gt 0 ]; do
        case "$1" in
            --resolver)
                [ $# -ge 2 ] || die "--resolver requires a value (e.g. --resolver 9.9.9.9)"
                case "$2" in -*|'') die "--resolver value missing or looks like a flag: '$2'" ;; esac
                resolver="$2"; shift 2 ;;
            --) shift; break ;;
            -*) die "unknown flag: $1" ;;
            *)  break ;;
        esac
    done

    command -v dig >/dev/null 2>&1 || command -v host >/dev/null 2>&1 \
        || die "check-dns requires 'dig' (dnsutils) or 'host'"
    local use_dig=0
    command -v dig >/dev/null 2>&1 && use_dig=1
    local dig_resolver=""
    [ -n "$resolver" ] && dig_resolver="@${resolver}"

    # --- DNS lookup helpers ---------------------------------------------------
    # These functions reference $use_dig and $dig_resolver via dynamic scoping.

    _dnscheck_a() {
        # First A or AAAA for $1, or empty string.
        if [ "$use_dig" -eq 1 ]; then
            { dig +short +time=5 $dig_resolver "$1" A
              dig +short +time=5 $dig_resolver "$1" AAAA; } 2>/dev/null \
                | grep -v '^;;' | grep -v '^$' | head -1
        else
            host -t A "$1" 2>/dev/null \
                | grep "has address" | awk '{print $NF}' | head -1
        fi
    }

    _dnscheck_mx() {
        # Lowest-priority MX answer for $1 (e.g. "10 example.com."), or empty string.
        if [ "$use_dig" -eq 1 ]; then
            dig +short +time=5 $dig_resolver "$1" MX 2>/dev/null \
                | grep -v '^;;' | grep -v '^$' | sort -n | head -1
        else
            host -t MX "$1" 2>/dev/null \
                | grep "mail is handled" | head -1 | sed 's/.*handled by //'
        fi
    }

    # First TXT for $1 whose value begins with literal $2 (case-insensitive),
    # or empty. $2 is matched as a literal string, not a regex.
    _dnscheck_txt() {
        local lookup="$1" prefix="$2"
        local raw
        if [ "$use_dig" -eq 1 ]; then
            raw=$(dig +short +time=5 $dig_resolver "$lookup" TXT 2>/dev/null \
                | tr -d '"' | grep -v '^;;' | grep -v '^$')
        else
            raw=$(host -t TXT "$lookup" 2>/dev/null \
                | grep "descriptive text" | sed 's/.*descriptive text //' | tr -d '"')
        fi
        printf '%s\n' "$raw" \
            | awk -v p="$prefix" 'tolower(substr($0,1,length(p)))==tolower(p){print; exit}'
    }

    # $1=ok|miss|hint  $2=record-name  $3=note (optional)
    _dnscheck_row() {
        local tag
        case "$1" in
            ok)   tag="[  ok  ]" ;;
            miss) tag="[MISSING]" ;;
            hint) tag="[ hint ]" ;;
            *)    tag="[  ??  ]" ;;
        esac
        printf '  %s  %-50s  %s\n' "$tag" "$2" "${3:-}"
    }

    # Continuation line showing what to add when a record is missing.
    _dnscheck_add() {
        printf '             add: "%s"\n' "$1"
    }

    # --- Query database for values that only the server knows ----------------
    local db_pass dkim_ed="" dkim_rsa="" mtasts_id=""
    db_pass=$(env_get POSTGRES_PASSWORD)
    if [ -n "$db_pass" ]; then
        # $domain is validated above; trim leading/trailing whitespace from psql -t output
        # but preserve interior spaces so the suggested DKIM TXT matches what the server logs.
        dkim_ed=$(dc exec -T -e PGPASSWORD="$db_pass" postgres \
            psql -h localhost -U rookery -d rookery -t -q -A \
            -c "SELECT 'v=DKIM1; k=ed25519; p='
                    || replace(encode(public_key_der,'base64'),chr(10),'')
                FROM dkim_keys dk JOIN domains d ON d.id = dk.domain_id
                WHERE d.domain='${domain}'
                  AND dk.selector='rookery-ed25519'
                  AND dk.is_active=TRUE LIMIT 1;" \
            2>/dev/null | tr -d '\n')
        dkim_rsa=$(dc exec -T -e PGPASSWORD="$db_pass" postgres \
            psql -h localhost -U rookery -d rookery -t -q -A \
            -c "SELECT 'v=DKIM1; k=rsa; p='
                    || replace(encode(public_key_der,'base64'),chr(10),'')
                FROM dkim_keys dk JOIN domains d ON d.id = dk.domain_id
                WHERE d.domain='${domain}'
                  AND dk.selector='rookery-rsa'
                  AND dk.is_active=TRUE LIMIT 1;" \
            2>/dev/null | tr -d '\n')
        mtasts_id=$(dc exec -T -e PGPASSWORD="$db_pass" postgres \
            psql -h localhost -U rookery -d rookery -t -q -A \
            -c "SELECT mta_sts_id FROM domains
                WHERE domain='${domain}' AND is_primary=TRUE LIMIT 1;" \
            2>/dev/null | tr -d '\n')
    fi

    # --- Output ---------------------------------------------------------------
    local sep="=============================================================="
    printf '\nDNS records for %s\n' "$domain"
    printf '%s\n' "$sep"

    # A / AAAA
    printf '\nA / AAAA  (all must resolve to your server IP)\n'
    local h a
    for h in "$domain" "openpgpkey.${domain}" "mta-sts.${domain}"; do
        a=$(_dnscheck_a "$h")
        if [ -n "$a" ]; then
            _dnscheck_row ok   "$h" "$a"
        else
            _dnscheck_row miss "$h" "(needs A or AAAA pointing to your server)"
        fi
    done

    # MX (must point to the bare primary, not a mail.* subdomain)
    printf '\nMX\n'
    local mx mx_host want_host
    mx=$(_dnscheck_mx "$domain")
    want_host=$(printf '%s' "$domain" | tr '[:upper:]' '[:lower:]')
    if [ -z "$mx" ]; then
        _dnscheck_row miss "$domain" "(e.g.  10 ${domain}.)"
    else
        mx_host=$(printf '%s\n' "$mx" \
            | awk '{ h=$NF; sub(/\.$/,"",h); print tolower(h) }')
        if [ "$mx_host" = "$want_host" ]; then
            _dnscheck_row ok "$domain" "$mx"
        else
            _dnscheck_row miss "$domain" "(found '$mx' — expected target '${domain}.')"
        fi
    fi

    # SPF
    printf '\nSPF TXT\n'
    local spf
    spf=$(_dnscheck_txt "$domain" "v=spf1")
    if [ -n "$spf" ]; then
        _dnscheck_row ok "$domain" "$spf"
    else
        _dnscheck_row miss "$domain"
        _dnscheck_add "v=spf1 a -all"
    fi

    # DKIM  (key values come from the database; start the server first)
    printf '\nDKIM TXT\n'
    local dkim_ed_name="rookery-ed25519._domainkey.${domain}"
    local dkim_rsa_name="rookery-rsa._domainkey.${domain}"
    local dkim_ed_dns dkim_rsa_dns
    dkim_ed_dns=$(_dnscheck_txt "$dkim_ed_name" "v=DKIM1")
    dkim_rsa_dns=$(_dnscheck_txt "$dkim_rsa_name" "v=DKIM1")

    if [ -n "$dkim_ed_dns" ]; then
        _dnscheck_row ok "$dkim_ed_name"
    elif [ -n "$dkim_ed" ]; then
        _dnscheck_row miss "$dkim_ed_name"
        _dnscheck_add "$dkim_ed"
    else
        _dnscheck_row miss "$dkim_ed_name" "(start the server first to generate keys)"
    fi

    if [ -n "$dkim_rsa_dns" ]; then
        _dnscheck_row ok "$dkim_rsa_name"
    elif [ -n "$dkim_rsa" ]; then
        _dnscheck_row miss "$dkim_rsa_name"
        _dnscheck_add "$dkim_rsa"
    else
        _dnscheck_row miss "$dkim_rsa_name" "(start the server first to generate keys)"
    fi

    # DMARC
    printf '\nDMARC TXT\n'
    local dmarc
    dmarc=$(_dnscheck_txt "_dmarc.${domain}" "v=DMARC1")
    if [ -n "$dmarc" ]; then
        _dnscheck_row ok "_dmarc.${domain}" "$dmarc"
    else
        _dnscheck_row miss "_dmarc.${domain}"
        _dnscheck_add "v=DMARC1; p=quarantine; rua=mailto:postmaster@${domain}"
    fi

    # MTA-STS TXT
    printf '\nMTA-STS TXT\n'
    local mtasts_txt
    mtasts_txt=$(_dnscheck_txt "_mta-sts.${domain}" "v=STSv1")
    if [ -n "$mtasts_txt" ]; then
        _dnscheck_row ok "_mta-sts.${domain}" "$mtasts_txt"
    elif [ -n "$mtasts_id" ]; then
        _dnscheck_row miss "_mta-sts.${domain}"
        _dnscheck_add "v=STSv1; id=${mtasts_id}"
    else
        _dnscheck_row miss "_mta-sts.${domain}" "(start server to get the id value)"
    fi

    # TLS-RPT (optional but recommended)
    printf '\nTLS-RPT TXT  (recommended)\n'
    local tlsrpt
    tlsrpt=$(_dnscheck_txt "_smtp._tls.${domain}" "v=TLSRPTv1")
    if [ -n "$tlsrpt" ]; then
        _dnscheck_row ok "_smtp._tls.${domain}" "$tlsrpt"
    else
        _dnscheck_row hint "_smtp._tls.${domain}"
        _dnscheck_add "v=TLSRPTv1; rua=mailto:postmaster@${domain}"
    fi

    printf '\n%s\n\n' "$sep"
}

# ---------------------------------------------------------------------------
# psql
# ---------------------------------------------------------------------------
cmd_psql() {
    need_init
    local db_pass
    db_pass=$(env_get POSTGRES_PASSWORD)
    dc exec -e PGPASSWORD="$db_pass" postgres psql -h localhost -U rookery -d rookery
}

# ---------------------------------------------------------------------------
# test
# ---------------------------------------------------------------------------
cmd_test() {
    need_init
    dc --profile test run --rm test
}

# ---------------------------------------------------------------------------
# vet
# ---------------------------------------------------------------------------
cmd_vet() {
    dc --profile lint run --rm lint
}

# ---------------------------------------------------------------------------
# exec <service> [cmd...]
# ---------------------------------------------------------------------------
cmd_exec() {
    [ $# -ge 1 ] || die "usage: rookery exec <service> [cmd...]"
    dc exec "$@"
}

# ---------------------------------------------------------------------------
# compose <args...>
# ---------------------------------------------------------------------------
cmd_compose() {
    docker compose -f "$SCRIPT_DIR/compose.yaml" "$@"
}

# ---------------------------------------------------------------------------
# help [subcommand]
# ---------------------------------------------------------------------------
cmd_help() {
    case "${1:-}" in
        init) cat >&2 <<'EOF'
rookery init [--domain X] [--email Y] [--name N] [--user U] [--no-prompt]

  Bootstrap a checkout. User-local; never needs sudo. Idempotent — safe
  to re-run after a git pull. Never overwrites existing files.

  Creates (if absent):
    rookery.toml    from example; flags or prompts fill domain/email/name
    .env            random secrets: ROOKERY_DB_PASSWORD, POSTGRES_PASSWORD,
                    ROOKERY_MASTER_KEY, ROOKERY_SESSION_KEY
    Caddyfile       generated from rookery.toml (inert in dev)
    rookery.service staged systemd unit with User= filled in (inert in dev)

  Flags:
    --domain X      Primary mail domain
    --email Y       Let's Encrypt contact email
    --name N        Instance display name
    --user U        Unix user for the systemd unit (default: whoami)
    --no-prompt     Skip interactive prompts; use flag values or defaults

  IMPORTANT: back up .env after init. Losing ROOKERY_MASTER_KEY bricks
  the instance's DKIM keys, sessions, and ACME credentials.
EOF
            ;;
        install) cat >&2 <<'EOF'
sudo rookery install

  Promote the staged ./rookery.service into a systemd unit:
    install -m644 ./rookery.service /etc/systemd/system/rookery.service
    systemctl daemon-reload

  Must be run as root. Does NOT enable or start the unit — that is the
  operator's deliberate next step:
    sudo systemctl enable --now rookery
EOF
            ;;
        start) cat >&2 <<'EOF'
rookery start [--prod] [docker compose up flags]

  Bring the stack up. Errors if rookery init has not been run.

  Without --prod (dev):  rookery + postgres + mailpit on :8025. Web UI at
                         http://localhost:8080. No Caddy, no TLS.
  With --prod:           rookery + postgres + caddy (TLS on 80/443).
                         The systemd unit always passes --prod.

  Extra flags are forwarded to docker compose up.
  Example: ./rookery start --prod -d    (detached; used by the systemd unit)
EOF
            ;;
        stop)
            printf 'rookery stop\n\n  Stop and remove running containers (docker compose down).\n' >&2 ;;
        restart)
            printf 'rookery restart [--prod]\n\n  Stop then start. Same --prod semantics as rookery start.\n' >&2 ;;
        update) cat >&2 <<'EOF'
rookery update

  git fetch && git pull --ff-only && docker compose build.
  Fails loudly on a divergent branch. Does NOT restart.
  After updating: sudo systemctl restart rookery  (or ./rookery restart)
EOF
            ;;
        logs)
            printf 'rookery logs [service]\n\n  Tail logs (default: rookery). Service names: rookery, postgres, mailpit, caddy.\n' >&2 ;;
        ps)
            printf 'rookery ps\n\n  Show running services (docker compose ps).\n' >&2 ;;
        invite) cat >&2 <<'EOF'
rookery invite create [validity_days]

  Generate a new invite URL and print it to stdout.

  validity_days   Optional. Days before the invite expires.
                  Omit for a non-expiring invite.

  Examples:
    ./rookery invite create        # no expiry
    ./rookery invite create 7      # expires in 7 days
EOF
            ;;
        send-mail) cat >&2 <<'EOF'
rookery send-mail [flags] <to> [from] [subject] [body]

  Inject a message into the dev stack's inbound SMTP (port 25).

  Flags:  --encrypted  --pubkey <file>  --fetch-key

  Examples:
    ./rookery send-mail alice@localhost
    ./rookery send-mail --encrypted --fetch-key alice@localhost
    ./rookery send-mail --encrypted --pubkey /tmp/alice.asc alice@localhost

  Env: ROOKERY_SMTP (default smtp://localhost:25)  ROOKERY_HTTP (default http://localhost:8080)
  Requires: curl. Encrypted mode additionally requires: gpg, python3.
EOF
            ;;
        check-dns) cat >&2 <<'EOF'
rookery check-dns [--resolver <addr>]

  Check all required DNS records for the primary domain and print their
  current status. Reads the domain from rookery.toml. Requires 'dig'
  (dnsutils / bind-utils) or 'host'.

  When the stack is running the DKIM public key values and MTA-STS ID
  are read directly from the database so the full required TXT values
  are shown next to any missing record.

  Records checked:
    A / AAAA    domain, openpgpkey.*, mta-sts.*
    MX          inbound mail delivery (target must be the bare primary)
    SPF TXT     outbound sender policy
    DKIM TXT    rookery-ed25519 and rookery-rsa selectors
    DMARC TXT   email authentication policy
    MTA-STS TXT strict TLS enforcement signal
    TLS-RPT TXT (recommended) TLS failure reporting

  Flags:
    --resolver <addr>   Query this resolver instead of the system default.
                        Useful to bypass local cache: --resolver 9.9.9.9
EOF
            ;;
        psql)
            printf 'rookery psql\n\n  Drop into an interactive psql shell inside the postgres container.\n' >&2 ;;
        test)
            printf 'rookery test\n\n  Run the Go test suite (docker compose --profile test run --rm test).\n' >&2 ;;
        vet)
            printf 'rookery vet\n\n  Run go vet (docker compose --profile lint run --rm lint).\n' >&2 ;;
        exec)
            printf 'rookery exec <service> [cmd...]\n\n  Escape hatch: docker compose exec against any service.\n' >&2 ;;
        compose)
            printf 'rookery compose <args...>\n\n  Escape hatch: arbitrary docker compose invocation.\n' >&2 ;;
        ""|help) cat >&2 <<'EOF'
rookery — operator and developer dispatcher for a rookery instance

Usage: ./rookery <subcommand> [flags] [args]
       ./rookery help <subcommand>

Bootstrap (run once per checkout / host):
  init [--domain X] [--email Y] [--name N] [--user U] [--no-prompt]
  sudo install

Stack management:
  start [--prod]         Bring the stack up (dev by default, --prod for TLS)
  stop                   Stop and remove containers
  restart [--prod]       stop then start
  update                 git pull --ff-only && docker compose build (no restart)
  logs [service]         Tail logs (default: rookery)
  ps                     Show running services

Operations:
  invite create [days]                  Generate an invite URL (stdout)
  send-mail [flags] <to> [from] [...]   Inject a message into inbound SMTP
  check-dns [--resolver <addr>]        Check and display all required DNS records
  psql                                  psql shell in the postgres container
  test                                  Run the Go test suite
  vet                                   Run go vet

Escape hatches:
  exec <service> [cmd...]   docker compose exec
  compose <args...>         raw docker compose
  help [subcommand]         this message, or per-subcommand usage
EOF
            ;;
        *) die "unknown subcommand '${1}' — run './rookery help' for the list" ;;
    esac
}

# ---------------------------------------------------------------------------
# Dispatch
# ---------------------------------------------------------------------------
case "${1:-}" in
    init)      shift; cmd_init      "$@" ;;
    install)   shift; cmd_install   "$@" ;;
    start)     shift; cmd_start     "$@" ;;
    stop)      shift; cmd_stop      "$@" ;;
    restart)   shift; cmd_restart   "$@" ;;
    update)    shift; cmd_update       ;;
    logs)      shift; cmd_logs      "$@" ;;
    ps)        shift; cmd_ps        "$@" ;;
    invite)     shift; cmd_invite     "$@" ;;
    send-mail)  shift; cmd_send_mail  "$@" ;;
    check-dns)  shift; cmd_check_dns  "$@" ;;
    psql)       shift; cmd_psql          ;;
    test)      shift; cmd_test         ;;
    vet)       shift; cmd_vet          ;;
    exec)      shift; cmd_exec      "$@" ;;
    compose)   shift; cmd_compose   "$@" ;;
    help)      shift; cmd_help      "$@" ;;
    "")               cmd_help;  exit 1 ;;
    *)         die "unknown subcommand '${1}' — run './rookery help' for the list" ;;
esac
